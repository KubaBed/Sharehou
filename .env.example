# API Settings for Sharehouse Frontend
# Set to 'false' to connect to your real backend, or 'true' to use the client-side mock data layer.
VITE_USE_MOCK_DATA=true

# The base URL for the API. When VITE_USE_MOCK_DATA is false, calls will be sent here.
# Since we configured a proxy in vite.config.js for '/api', you can leave this as '/api' or set it to your full backend host.
VITE_API_URL=/api
